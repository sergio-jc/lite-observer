# Copy to .env and adjust if host ports are already in use.
# Docker Compose reads .env next to docker-compose.yml for substitution.

# Web UI (nginx in container listens on 80; this is the port on your machine)
FRONTEND_PORT=3000

# Lite Observer API (same port inside and outside the container).
# If you change BACKEND_PORT, run: docker compose build frontend && docker compose up -d
# so the UI is rebuilt with the correct VITE_API_URL.
BACKEND_PORT=3001

# PostgreSQL (container still uses 5432 internally)
POSTGRES_PORT=5433
